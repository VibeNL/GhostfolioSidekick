@page "/tax-details"
@inherits PortfolioViewer.WASM.Pages.TaxDetailsBase

<PageTitle>Tax Details</PageTitle>

<h1>Tax Details Per Year Per Account</h1>

<div class="mb-3">
	<label for="yearSelect" class="form-label fw-bold">Select Year:</label>
	<select id="yearSelect" class="form-select w-auto d-inline-block" @bind="SelectedYear">
		@foreach (var year in Years)
		{
			<option value="@year">@year</option>
		}
	</select>
</div>

@if (Accounts == null)
{
	<div>Loading accounts...</div>
}
else
{
    foreach (var account in Accounts.Where(HasValues))
    {
        <div class="card mb-4">
            <div class="card-header">
                <span class="fw-bold">@account.Name</span> <span class="text-muted ms-2">@account.AccountType</span>
            </div>
            <div class="card-body">
               <!-- Start/End Positions and Values -->
               <div class="mb-3">
                   <h5>Position Difference (1-1 vs 31-12)</h5>
                   <table class="table table-sm table-bordered w-auto">
                       <thead>
                           <tr>
                               <th></th>
                               <th>1-1</th>
                               <th>31-12</th>
                               <th>Difference</th>
                           </tr>
                       </thead>
                       <tbody>
                           <tr>
                               <td class="fw-bold">Value</td>
                               <td>@account.StartValue.ToString("C")</td>
                               <td>@account.EndValue.ToString("C")</td>
                               <td>@FormatCurrency(account.EndValue - account.StartValue, account)</td>
                           </tr>
                           <tr>
                               <td class="fw-bold">Cash Balance</td>
                               <td>@account.StartCashBalance.ToString("C")</td>
                               <td>@account.EndCashBalance.ToString("C")</td>
                               <td>@FormatCurrency(account.EndCashBalance - account.StartCashBalance, account)</td>
                           </tr>
                       </tbody>
                   </table>
                   <div class="mt-2">
                       <span class="fw-bold">Start Holdings:</span>
                       @if (account.StartHoldings != null && account.StartHoldings.Any())
                       {
                           <table class="table table-sm table-bordered mt-1">
                               <thead>
                                   <tr>
                                       <th>Symbol</th>
                                       <th>Quantity</th>
                                       <th>Value</th>
                                       <th>Acquisition Date</th>
                                   </tr>
                               </thead>
                               <tbody>
                                   @foreach (var holding in account.StartHoldings)
                                   {
                                       <tr>
                                           <td>@holding.Symbol</td>
                                           <td>@holding.Quantity</td>
                                           <td>@holding.Value.ToString("C")</td>
                                           <td>@holding.AcquisitionDate.ToString("dd/MM/yyyy")</td>
                                       </tr>
                                   }
                               </tbody>
                           </table>
                       }
                       else
                       {
                           <p>No start holdings for @SelectedYear.</p>
                       }
                   </div>
                   <div class="mt-2">
                       <span class="fw-bold">End Holdings:</span>
                       @if (account.EndHoldings != null && account.EndHoldings.Any())
                       {
                           <table class="table table-sm table-bordered mt-1">
                               <thead>
                                   <tr>
                                       <th>Symbol</th>
                                       <th>Quantity</th>
                                       <th>Value</th>
                                       <th>Acquisition Date</th>
                                   </tr>
                               </thead>
                               <tbody>
                                   @foreach (var holding in account.EndHoldings)
                                   {
                                       <tr>
                                           <td>@holding.Symbol</td>
                                           <td>@holding.Quantity</td>
                                           <td>@holding.Value.ToString("C")</td>
                                           <td>@holding.AcquisitionDate.ToString("dd/MM/yyyy")</td>
                                       </tr>
                                   }
                               </tbody>
                           </table>
                       }
                       else
                       {
                           <p>No end holdings for @SelectedYear.</p>
                       }
                   </div>
               </div>
               <!-- Holdings -->
               <h5>Holdings</h5>
               @if (account.Holdings != null && account.Holdings.Any(h => h.AcquisitionDate.Year == SelectedYear))
               {
                   <table class="table table-sm table-bordered">
                       <thead>
                           <tr>
                               <th>Symbol</th>
                               <th>Quantity</th>
                               <th>Value</th>
                               <th>Acquisition Date</th>
                           </tr>
                       </thead>
                       <tbody>
                           @foreach (var holding in account.Holdings.Where(h => h.AcquisitionDate.Year == SelectedYear))
                           {
                               <tr>
                                   <td>@holding.Symbol</td>
                                   <td>@holding.Quantity</td>
                                   <td>@holding.Value.ToString("C")</td>
                                   <td>@holding.AcquisitionDate.ToString("dd/MM/yyyy")</td>
                               </tr>
                           }
                       </tbody>
                   </table>
               }
               else
               {
                   <p>No holdings for @SelectedYear.</p>
               }

               <!-- Transactions -->
               <h5>Transactions</h5>
               @if (account.Transactions != null && account.Transactions.Any(tx => tx.Type != "KnownBalance" && tx.Amount != 0))
               {
                   <table class="table table-sm table-bordered">
                       <thead>
                           <tr>
                               <th>Date</th>
                               <th>Type</th>
                               <th>Symbol</th>
                               <th>Amount</th>
                               <th>Fees</th>
                               <th>Notes</th>
                           </tr>
                       </thead>
                       <tbody>
                           @foreach (var tx in account.Transactions.Where(tx => tx.Type != "KnownBalance" && tx.Amount != 0))
                           {
                               <tr>
                                   <td>@tx.Date.ToString("dd/MM/yyyy")</td>
                                   <td>@tx.Type</td>
                                   <td>@tx.Symbol</td>
                                   <td>@FormatCurrency(tx.Amount, account)</td>
                                   <td>@FormatCurrency(tx.Fees, account)</td>
                                   <td>@tx.Notes</td>
                               </tr>
                           }
                       </tbody>
                   </table>
               }
               else
               {
                   <p>No transactions for @SelectedYear.</p>
               }

				<!-- Dividends -->
				<h5>Dividends</h5>
				@if (account.Dividends != null && account.Dividends.Any())
				{
					<table class="table table-sm table-bordered">
						<thead>
							<tr>
								<th>Date</th>
								<th>Symbol</th>
								<th>Amount</th>
								<th>Tax Withheld</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var div in account.Dividends)
							{
								<tr>
									<td>@div.Date.ToString("dd/MM/yyyy")</td>
									<td>@div.Symbol</td>
									<td>@div.Amount.ToString("C")</td>
									<td>@div.TaxWithheld.ToString("C")</td>
								</tr>
							}
						</tbody>
					</table>
				}
				else
				{
					<p>No dividends for @SelectedYear.</p>
				}

				<!-- Realized Gains/Losses -->
				<h5>Realized Gains/Losses</h5>
				@if (account.RealizedGainsLosses != null && account.RealizedGainsLosses.Any())
				{
					<table class="table table-sm table-bordered">
						<thead>
							<tr>
								<th>Symbol</th>
								<th>Gain/Loss</th>
								<th>Date</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var gl in account.RealizedGainsLosses)
							{
								<tr>
									<td>@gl.Symbol</td>
									<td>@gl.Amount.ToString("C")</td>
									<td>@gl.Date.ToString("dd/MM/yyyy")</td>
								</tr>
							}
						</tbody>
					</table>
				}
				else
				{
					<p>No realized gains/losses for @SelectedYear.</p>
				}
			</div>
		</div>
	}
}


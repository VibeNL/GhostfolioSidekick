@page "/tax-details"
@inherits PortfolioViewer.WASM.Pages.TaxDetailsBase

<PageTitle>Tax Details</PageTitle>

<h1>Tax Details Per Year Per Account</h1>

<div class="mb-3">
	<label for="yearSelect" class="form-label fw-bold">Select Year:</label>
	<select id="yearSelect" class="form-select w-auto d-inline-block" @bind="SelectedYear">
		@foreach (var year in Years)
		{
			<option value="@year">@year</option>
		}
	</select>
</div>

@if (Accounts == null)
{
	<div>Loading accounts...</div>
}
else
{
    foreach (var account in Accounts.Where(HasValues))
    {
        <div class="card mb-4">
            <div class="card-header">
                <span class="fw-bold">@account.Name</span> <span class="text-muted ms-2">@account.AccountType</span>
            </div>
            <div class="card-body">
                <h5>Positions Overview (1-1 and 31-12)</h5>
                <table class="table table-sm table-bordered w-auto">
                    <thead>
                        <tr>
                            <th>Symbol</th>
                            <th>Quantity 1-1</th>
                            <th>Value 1-1</th>
                            <th>Quantity 31-12</th>
                            <th>Value 31-12</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if ((account.StartHoldings != null && account.StartHoldings.Any()) || (account.EndHoldings != null && account.EndHoldings.Any()))
                        {
                            var startSymbols = account.StartHoldings?.Select(h => h.Symbol).ToHashSet() ?? [];
                            var endSymbols = account.EndHoldings?.Select(h => h.Symbol).ToHashSet() ?? [];
                            var allSymbols = startSymbols.Union(endSymbols).OrderBy(s => s);
                            var totalStartValue = 0m;
                            var totalEndValue = 0m;
                            foreach (var symbol in allSymbols)
                            {
                                var start = account.StartHoldings?.FirstOrDefault(h => h.Symbol == symbol);
                                var end = account.EndHoldings?.FirstOrDefault(h => h.Symbol == symbol);
                                totalStartValue += start?.Value ?? 0;
                                totalEndValue += end?.Value ?? 0;
                                <tr>
                                    <td>@symbol</td>
                                    <td>@(start?.Quantity ?? 0)</td>
                                    <td>@FormatCurrency(start?.Value ?? 0)</td>
                                    <td>@(end?.Quantity ?? 0)</td>
                                    <td>@FormatCurrency(end?.Value ?? 0)</td>
                                </tr>
                            }
                            <tr class="fw-bold">
                                <td>Total Balance</td>
                                <td></td>
                                <td>@FormatCurrency(totalStartValue)</td>
                                <td></td>
                                <td>@FormatCurrency(totalEndValue)</td>
                            </tr>
                            <tr class="fw-bold">
                                <td>Total Cash</td>
                                <td></td>
                                <td>@FormatCurrency(account.StartCashBalance)</td>
                                <td></td>
                                <td>@FormatCurrency(account.EndCashBalance)</td>
                            </tr>
                        }
                        else
                        {
                            <tr><td colspan="5">No holdings for @SelectedYear.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}


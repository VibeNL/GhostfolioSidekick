@page "/tax-details"
@using GhostfolioSidekick.PortfolioViewer.WASM.Data.Models
@using PortfolioViewer.WASM.Data.Services
@inject IAccountDataService AccountService
@inject ITransactionService TransactionService
@inject NavigationManager Navigation

<PageTitle>Tax Details</PageTitle>

<h1>Tax Details Per Year Per Account</h1>

<div class="mb-3">
	<label for="yearSelect" class="form-label fw-bold">Select Year:</label>
	<select id="yearSelect" class="form-select w-auto d-inline-block" @bind="SelectedYear">
		@foreach (var year in Years)
		{
			<option value="@year">@year</option>
		}
	</select>
</div>

@if (Accounts == null)
{
	<div>Loading accounts...</div>
}
else
{
	@foreach (var account in Accounts)
	{
		<div class="card mb-4">
			<div class="card-header">
				<span class="fw-bold">@account.Name</span> <span class="text-muted ms-2">@account.AccountType</span>
			</div>
			<div class="card-body">
				<!-- Holdings -->
				<h5>Holdings</h5>
				@if (account.Holdings != null && account.Holdings.Any())
				{
					<table class="table table-sm table-bordered">
						<thead>
							<tr>
								<th>Symbol</th>
								<th>Quantity</th>
								<th>Value</th>
								<th>Acquisition Date</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var holding in account.Holdings)
							{
								<tr>
									<td>@holding.Symbol</td>
									<td>@holding.Quantity</td>
									<td>@holding.Value.ToString("C")</td>
									<td>@holding.AcquisitionDate.ToString("dd/MM/yyyy")</td>
								</tr>
							}
						</tbody>
					</table>
				}
				else
				{
					<p>No holdings for @SelectedYear.</p>
				}

				<!-- Transactions -->
				<h5>Transactions</h5>
				@if (account.Transactions != null && account.Transactions.Any())
				{
					<table class="table table-sm table-bordered">
						<thead>
							<tr>
								<th>Date</th>
								<th>Type</th>
								<th>Symbol</th>
								<th>Amount</th>
								<th>Fees</th>
								<th>Notes</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var tx in account.Transactions)
							{
								<tr>
									<td>@tx.Date.ToString("dd/MM/yyyy")</td>
									<td>@tx.Type</td>
									<td>@tx.Symbol</td>
									<td>@tx.Amount.ToString("C")</td>
									<td>@tx.Fees.ToString("C")</td>
									<td>@tx.Notes</td>
								</tr>
							}
						</tbody>
					</table>
				}
				else
				{
					<p>No transactions for @SelectedYear.</p>
				}

				<!-- Dividends -->
				<h5>Dividends</h5>
				@if (account.Dividends != null && account.Dividends.Any())
				{
					<table class="table table-sm table-bordered">
						<thead>
							<tr>
								<th>Date</th>
								<th>Symbol</th>
								<th>Amount</th>
								<th>Tax Withheld</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var div in account.Dividends)
							{
								<tr>
									<td>@div.Date.ToString("dd/MM/yyyy")</td>
									<td>@div.Symbol</td>
									<td>@div.Amount.ToString("C")</td>
									<td>@div.TaxWithheld.ToString("C")</td>
								</tr>
							}
						</tbody>
					</table>
				}
				else
				{
					<p>No dividends for @SelectedYear.</p>
				}

				<!-- Realized Gains/Losses -->
				<h5>Realized Gains/Losses</h5>
				@if (account.RealizedGainsLosses != null && account.RealizedGainsLosses.Any())
				{
					<table class="table table-sm table-bordered">
						<thead>
							<tr>
								<th>Symbol</th>
								<th>Gain/Loss</th>
								<th>Date</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var gl in account.RealizedGainsLosses)
							{
								<tr>
									<td>@gl.Symbol</td>
									<td>@gl.Amount.ToString("C")</td>
									<td>@gl.Date.ToString("dd/MM/yyyy")</td>
								</tr>
							}
						</tbody>
					</table>
				}
				else
				{
					<p>No realized gains/losses for @SelectedYear.</p>
				}
			</div>
		</div>
	}
}

@code {
	private List<int> Years = new();
	private int SelectedYear;
    private List<TaxAccountDisplayModel>? Accounts;

	protected override async Task OnInitializedAsync()
	{
		Years = await TransactionService.GetAvailableYearsAsync();
		SelectedYear = Years.LastOrDefault(DateTime.Now.Year);
		await LoadAccounts();
	}

	private async Task LoadAccounts()
	{
		Accounts = await AccountService.GetTaxAccountDetailsAsync(SelectedYear);
	}

    private async Task OnYearChanged(ChangeEventArgs e)
    {
        if (e.Value is string s && int.TryParse(s, out var year))
        {
            SelectedYear = year;
            await LoadAccounts();
        }
    }
}

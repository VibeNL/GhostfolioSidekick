@page "/tax-report"
@using Microsoft.AspNetCore.Authorization
@using GhostfolioSidekick.Model
@using GhostfolioSidekick.PortfolioViewer.WASM.Components
@using GhostfolioSidekick.PortfolioViewer.WASM.Models
@attribute [Authorize]

<PageTitle>Tax Report (NL Box 3)</PageTitle>

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12">
            <h2><i class="bi bi-file-earmark-ruled me-2"></i>Tax Report – Netherlands Box 3</h2>
            <p class="text-muted">Total asset value and cash balance per account on 1 January and 31 December of each year.</p>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center py-5">
                        <div class="spinner-border text-primary mb-3" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <h5 class="text-muted">Loading Tax Report...</h5>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (HasError)
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-danger" role="alert">
                    <h4 class="alert-heading">Error Loading Data</h4>
                    <p>@ErrorMessage</p>
                </div>
            </div>
        </div>
    }
    else if (!ReportData.Any())
    {
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-file-earmark-ruled text-muted" style="font-size: 4rem;"></i>
                        <h5 class="text-muted mt-3">No Tax Data Found</h5>
                        <p class="text-muted">No snapshot data is available yet. Please wait for the first sync to complete.</p>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Year Selector -->
        <div class="row mb-3">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-body py-2">
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <span class="text-muted me-1"><i class="bi bi-calendar3 me-1"></i>Year:</span>
                            <button class="btn btn-sm @(SelectedYear == null ? "btn-primary" : "btn-outline-primary")"
                                    @onclick="() => SelectYear(null)">
                                All
                            </button>
                            @foreach (var y in Years)
                            {
                                var capturedYear = y;
                                <button class="btn btn-sm @(SelectedYear == capturedYear ? "btn-primary" : "btn-outline-primary")"
                                        @onclick="() => SelectYear(capturedYear)">
                                    @capturedYear
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Year Cards -->
        @foreach (var year in VisibleYears)
        {
            var dates = GetDatesForYear(year).ToList();
            var startDate = dates.FirstOrDefault();
            var endDate = dates.Count > 1 ? dates.Last() : (DateOnly?)null;
            var compRows = GetComparisonRows(year).ToList();
            var compTotal = GetComparisonTotal(year);

            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-calendar3 me-2"></i>@year
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0 align-middle">
                            <thead>
                                <!-- Date group headers -->
                                <tr class="table-light">
                                    <th rowspan="2" class="align-middle">Account</th>
                                    <th colspan="3" class="text-center border-start">
                                        <i class="bi bi-calendar-check me-1"></i>@startDate.ToString("d MMMM yyyy")
                                    </th>
                                    @if (endDate.HasValue)
                                    {
                                        <th colspan="3" class="text-center border-start">
                                            <i class="bi bi-calendar-check me-1"></i>@endDate.Value.ToString("d MMMM yyyy")
                                        </th>
                                        <th class="text-center border-start align-middle" rowspan="2">Change</th>
                                        <th class="text-center border-start align-middle" rowspan="2">Split Change<br />(Asset/Cash)</th>
                                    }
                                </tr>
                                <!-- Column sub-headers -->
                                <tr class="table-light">
                                    <th class="text-end border-start">Assets</th>
                                    <th class="text-end">Cash</th>
                                    <th class="text-end fw-bold">Total</th>
                                    @if (endDate.HasValue)
                                    {
                                        <th class="text-end border-start">Assets</th>
                                        <th class="text-end">Cash</th>
                                        <th class="text-end fw-bold">Total</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in compRows)
                                {
                                    var change = (row.End?.TotalValue.Amount ?? row.Start?.TotalValue.Amount ?? 0)
                                               - (row.Start?.TotalValue.Amount ?? 0);
                                    var assetChange = (row.End?.AssetValue.Amount ?? row.Start?.AssetValue.Amount ?? 0)
                                                    - (row.Start?.AssetValue.Amount ?? 0);
                                    var cashChange = (row.End?.CashBalance.Amount ?? row.Start?.CashBalance.Amount ?? 0)
                                                    - (row.Start?.CashBalance.Amount ?? 0);
                                    <tr>
                                        <td>@row.AccountName</td>
                                        <!-- Start date -->
                                        <td class="text-end border-start">
                                            @if (row.Start != null)
                                            {
                                                <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(row.Start.AssetValue)" />
                                            }
                                        </td>
                                        <td class="text-end">
                                            @if (row.Start != null)
                                            {
                                                <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(row.Start.CashBalance)" />
                                            }
                                        </td>
                                        <td class="text-end fw-semibold">
                                            @if (row.Start != null)
                                            {
                                                <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(row.Start.TotalValue)" />
                                            }
                                        </td>
                                        <!-- End date -->
                                        @if (endDate.HasValue)
                                        {
                                            <td class="text-end border-start">
                                                @if (row.End != null)
                                                {
                                                    <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(row.End.AssetValue)" />
                                                }
                                            </td>
                                            <td class="text-end">
                                                @if (row.End != null)
                                                {
                                                    <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(row.End.CashBalance)" />
                                                }
                                            </td>
                                            <td class="text-end fw-semibold">
                                                @if (row.End != null)
                                                {
                                                    <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(row.End.TotalValue)" />
                                                }
                                            </td>
                                            <td class="text-end border-start @ChangeClass(change)">
                                                <i class="bi @ChangeIcon(change) me-1"></i>
                                                <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(row.End?.TotalValue.Currency != null ? new GhostfolioSidekick.Model.Money(row.End.TotalValue.Currency, change) : new GhostfolioSidekick.Model.Money(row.Start!.TotalValue.Currency, change))" />
                                            </td>
                                            <td class="text-end border-start">
                                                <span class="@ChangeClass(assetChange)">
                                                    <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(row.End?.AssetValue.Currency != null ? new GhostfolioSidekick.Model.Money(row.End.AssetValue.Currency, assetChange) : new GhostfolioSidekick.Model.Money(row.Start!.AssetValue.Currency, assetChange))" />
                                                </span>
                                                /
                                                <span class="@ChangeClass(cashChange)">
                                                    <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(row.End?.CashBalance.Currency != null ? new GhostfolioSidekick.Model.Money(row.End.CashBalance.Currency, cashChange) : new GhostfolioSidekick.Model.Money(row.Start!.CashBalance.Currency, cashChange))" />
                                                </span>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                            @if (compRows.Count > 1)
                            {
                                var totalChange = (compTotal.End?.TotalValue.Amount ?? compTotal.Start?.TotalValue.Amount ?? 0)
                                               - (compTotal.Start?.TotalValue.Amount ?? 0);
                                var totalAssetChange = (compTotal.End?.AssetValue.Amount ?? compTotal.Start?.AssetValue.Amount ?? 0)
                                                    - (compTotal.Start?.AssetValue.Amount ?? 0);
                                var totalCashChange = (compTotal.End?.CashBalance.Amount ?? compTotal.Start?.CashBalance.Amount ?? 0)
                                                    - (compTotal.Start?.CashBalance.Amount ?? 0);
                                <tfoot class="table-primary fw-bold">
                                    <tr>
                                        <td>Total</td>
                                        <td class="text-end border-start">
                                            @if (compTotal.Start != null)
                                            {
                                                <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(compTotal.Start.AssetValue)" />
                                            }
                                        </td>
                                        <td class="text-end">
                                            @if (compTotal.Start != null)
                                            {
                                                <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(compTotal.Start.CashBalance)" />
                                            }
                                        </td>
                                        <td class="text-end">
                                            @if (compTotal.Start != null)
                                            {
                                                <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(compTotal.Start.TotalValue)" />
                                            }
                                        </td>
                                        @if (endDate.HasValue)
                                        {
                                            <td class="text-end border-start">
                                                @if (compTotal.End != null)
                                                {
                                                    <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(compTotal.End.AssetValue)" />
                                                }
                                            </td>
                                            <td class="text-end">
                                                @if (compTotal.End != null)
                                                {
                                                    <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(compTotal.End.CashBalance)" />
                                                }
                                            </td>
                                            <td class="text-end">
                                                @if (compTotal.End != null)
                                                {
                                                    <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(compTotal.End.TotalValue)" />
                                                }
                                            </td>
                                            <td class="text-end border-start @ChangeClass(totalChange)">
                                                <i class="bi @ChangeIcon(totalChange) me-1"></i>
                                                <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(compTotal.End?.TotalValue.Currency != null ? new GhostfolioSidekick.Model.Money(compTotal.End.TotalValue.Currency, totalChange) : new GhostfolioSidekick.Model.Money(compTotal.Start!.TotalValue.Currency, totalChange))" />
                                            </td>
                                            <td class="text-end border-start">
                                                <span class="@ChangeClass(totalAssetChange)">
                                                    <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(compTotal.End?.AssetValue.Currency != null ? new GhostfolioSidekick.Model.Money(compTotal.End.AssetValue.Currency, totalAssetChange) : new GhostfolioSidekick.Model.Money(compTotal.Start!.AssetValue.Currency, totalAssetChange))" />
                                                </span>
                                                /
                                                <span class="@ChangeClass(totalCashChange)">
                                                    <PrivacyValue Value="@CurrencyDisplay.DisplaySignAndAmount(compTotal.End?.CashBalance.Currency != null ? new GhostfolioSidekick.Model.Money(compTotal.End.CashBalance.Currency, totalCashChange) : new GhostfolioSidekick.Model.Money(compTotal.Start!.CashBalance.Currency, totalCashChange))" />
                                                </span>
                                            </td>
                                        }
                                    </tr>
                                </tfoot>
                            }
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

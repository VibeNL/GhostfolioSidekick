@page "/"
@using Microsoft.AspNetCore.Authorization
@using GhostfolioSidekick.Model
@using GhostfolioSidekick.PortfolioViewer.WASM.Components
@attribute [Authorize]


@if (IsLoading)
{
    <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 40vh;">
        <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <div class="fw-bold">Loading...</div>
    </div>
}
else
{
    <PageTitle>Dashboard</PageTitle>

    <h1><i class="bi bi-speedometer2 me-2"></i>Portfolio Dashboard</h1>

    <!-- Portfolio KPI Summary Cards -->
    @if (LastSyncTime.HasValue)
    {
        <div class="row g-3 mb-4">
            @if (IsSummaryLoading)
            {
                <div class="col-12 text-center py-3">
                    <div class="spinner-border spinner-border-sm text-primary me-2" role="status">
                        <span class="visually-hidden">Loading summary...</span>
                    </div>
                    <span class="text-muted">Loading portfolio summary...</span>
                </div>
            }
            else
            {
                <!-- Total Value -->
                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="card h-100 border-primary shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-2">
                                <div class="rounded-circle bg-primary bg-opacity-10 p-2 me-3">
                                    <i class="bi bi-wallet2 text-primary fs-5"></i>
                                </div>
                                <span class="text-muted small fw-semibold text-uppercase">Total Value</span>
                            </div>
                            <div class="h4 mb-0 fw-bold">
                                <PrivacyValue Value="@($"{SummaryCurrency} {TotalValue:N2}")" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Total Invested -->
                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="card h-100 border-info shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-2">
                                <div class="rounded-circle bg-info bg-opacity-10 p-2 me-3">
                                    <i class="bi bi-cash-stack text-info fs-5"></i>
                                </div>
                                <span class="text-muted small fw-semibold text-uppercase">Total Invested</span>
                            </div>
                            <div class="h4 mb-0 fw-bold">
                                <PrivacyValue Value="@($"{SummaryCurrency} {TotalInvested:N2}")" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Gain / Loss -->
                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="card h-100 @(TotalGainLoss >= 0 ? "border-success" : "border-danger") shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-2">
                                <div class="rounded-circle @(TotalGainLoss >= 0 ? "bg-success" : "bg-danger") bg-opacity-10 p-2 me-3">
                                    <i class="bi @(TotalGainLoss >= 0 ? "bi-graph-up-arrow text-success" : "bi-graph-down-arrow text-danger") fs-5"></i>
                                </div>
                                <span class="text-muted small fw-semibold text-uppercase">Total Gain / Loss</span>
                            </div>
                            <div class="h4 mb-0 fw-bold @(TotalGainLoss >= 0 ? "text-success" : "text-danger")">
                                <PrivacyValue Value="@($"{(TotalGainLoss >= 0 ? "+" : "")}{SummaryCurrency} {TotalGainLoss:N2}")" />
                            </div>
                            <div class="small @(TotalGainLoss >= 0 ? "text-success" : "text-danger")">
                                <PrivacyValue Value="@($"{(TotalGainLossPercentage >= 0 ? "+" : "")}{TotalGainLossPercentage:N2}%")" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Holdings & Dividends -->
                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="card h-100 border-warning shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-2">
                                <div class="rounded-circle bg-warning bg-opacity-10 p-2 me-3">
                                    <i class="bi bi-pie-chart text-warning fs-5"></i>
                                </div>
                                <span class="text-muted small fw-semibold text-uppercase">Holdings</span>
                            </div>
                            <div class="h4 mb-0 fw-bold">@HoldingsCount</div>
                            @if (UpcomingDividendsCount > 0)
                            {
                                <div class="small text-muted mt-1">
                                    <a href="/dividends" class="text-decoration-none">
                                        <i class="bi bi-cash-coin me-1 text-success"></i>@UpcomingDividendsCount upcoming dividend@(UpcomingDividendsCount != 1 ? "s" : "")
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Quick Links -->
        <div class="row g-2 mb-4">
            <div class="col-12">
                <div class="d-flex flex-wrap gap-2">
                    <a href="/holdings" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-pie-chart me-1"></i>Holdings
                    </a>
                    <a href="/portfolio-timeseries" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-bar-chart-line me-1"></i>Performance
                    </a>
                    <a href="/top-movers" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-lightning-charge me-1"></i>Top Movers
                    </a>
                    <a href="/dividends" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-cash-coin me-1"></i>Dividends
                    </a>
                    <a href="/transactions" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-list-ul me-1"></i>Transactions
                    </a>
                </div>
            </div>
        </div>
    }

    <hr />

    <h5 class="text-muted mb-3"><i class="bi bi-arrow-repeat me-2"></i>Data Sync</h5>

    <!-- Migration Warning Section -->
    @if (MigrationStatus != null && MigrationStatus.PendingMigrations.Count > 0)
    {
        <div class="alert alert-danger mb-3">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Database Migrations Required!</strong> The server database is missing migrations and may be out of sync with the application.<br />
            <span class="fw-bold">Please update the database before syncing.</span>
            <div class="mt-2">
                <small>Pending migrations: @string.Join(", ", MigrationStatus.PendingMigrations)</small>
            </div>
        </div>
    }

    <!-- Version Info Section -->
    @if (IsUpdateAvailable)
    {
        <div class="alert alert-warning mb-3">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Update Available!</strong> A new version is available. Please refresh the page to update.
            <button class="btn btn-sm btn-warning ms-2" @onclick="RefreshPage" disabled="@IsReloading">
                @if (IsReloading)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    <span>Reloading...</span>
                }
                else
                {
                    <i class="bi bi-arrow-clockwise me-1"></i>
                    <span>Refresh Now</span>
                }
            </button>
            <div class="mt-2">
                <small>Client: @ClientVersion | Server: @ServerVersion</small>
            </div>
        </div>
    }

    @if (LastSyncTime.HasValue)
    {
        <div class="alert alert-info mb-3">
            <strong>Last sync:</strong> @LastSyncTime.Value.ToString("dd/MM/yyyy HH:mm:ss")
            <small class="text-muted ms-2">(@GetTimeSinceLastSync())</small>
            @if (!IsSyncing && GetDaysSinceLastSync() <= 7)
            {
                <div class="mt-2">
                    <small class="text-info">
                        <i class="bi bi-lightning-fill me-1"></i>
                        Next sync will be fast (partial sync - only missing days)
                    </small>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning mb-3">
            <strong>No sync yet:</strong> Please perform your first sync to get started.
            <div class="mt-2">
                <small class="text-muted">
                    <i class="bi bi-info-circle me-1"></i>
                    First sync downloads all data and may take longer
                </small>
            </div>
        </div>
    }

    <!-- Sync Progress Section -->
    <div class="mb-4">
        <p>@CurrentAction</p>
        @if (IsWakeLockActive)
        {
            <div class="mb-2">
                <small class="text-success">
                    <i class="bi bi-shield-fill-check me-1"></i>
                    Screen wake lock is active - device will not sleep
                </small>
            </div>
        }
        <div class="progress">
            <div class="progress-bar" role="progressbar" style="width: @Progress%;" aria-valuenow="@Progress" aria-valuemin="0" aria-valuemax="100">
                @Progress%
            </div>
        </div>
    </div>

    <!-- Sync Buttons Section -->
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-primary" @onclick="StartSync" disabled="@IsSyncing">
            @if (IsSyncing)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            }
            else
            {
                <i class="bi bi-arrow-repeat me-2"></i>
            }
            @GetSyncButtonText()
        </button>

        @if (!IsSyncing)
        {
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-gear me-1"></i>
                    Options
                </button>
                <ul class="dropdown-menu">
                    @if (LastSyncTime.HasValue)
                    {
                        <li>
                            <button class="dropdown-item" @onclick="StartFullSync">
                                <i class="bi bi-arrow-clockwise me-2"></i>
                                Force Full Sync
                                <small class="text-muted d-block">Download all data (slower but complete)</small>
                            </button>
                        </li>
                    }
                    <li>
                        <button class="dropdown-item text-danger" @onclick="DeleteAllData">
                            <i class="bi bi-trash me-2"></i>
                            Delete All Data
                            <small class="text-muted d-block">Remove all synced data from local database</small>
                        </button>
                    </li>
                </ul>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <div class="alert @(_isError ? "alert-danger" : "alert-success") mt-3" role="alert">
            <i class="bi @(_isError ? "bi-exclamation-triangle" : "bi-check-circle") me-2"></i>
            @_statusMessage
        </div>
    }

    <!-- Footer Version Info (less prominent) -->
    @if (!IsUpdateAvailable && !string.IsNullOrEmpty(ClientVersion))
    {
        <footer class="text-center mt-5 mb-2 text-muted" style="font-size: 0.95em;">
            <i class="bi bi-info-circle me-1"></i>
            Version: @ClientVersion
            @if (!string.IsNullOrEmpty(ServerVersion))
            {
                <span class="text-success ms-2">
                    <i class="bi bi-check-circle me-1"></i>
                    Up to date
                </span>
            }
        </footer>
    }
}

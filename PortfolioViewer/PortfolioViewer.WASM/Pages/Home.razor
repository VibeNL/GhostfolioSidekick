@page "/"
@using Microsoft.AspNetCore.Authorization
@using GhostfolioSidekick.Model
@attribute [Authorize]

@if (IsLoading)
{
    <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 40vh;">
        <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <div class="fw-bold">Loading...</div>
    </div>
}
else
{
    <PageTitle>Dashboard</PageTitle>

    @if (MigrationStatus != null && MigrationStatus.PendingMigrations.Count > 0)
    {
        <div class="alert alert-danger mb-3">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Database Migrations Required!</strong> The server database is missing migrations and may be out of sync with the application.<br />
            <span class="fw-bold">Please update the database before syncing.</span>
            <div class="mt-2">
                <small>Pending migrations: @string.Join(", ", MigrationStatus.PendingMigrations)</small>
            </div>
        </div>
    }

    @if (IsUpdateAvailable)
    {
        <div class="alert alert-warning mb-3">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Update Available!</strong> A new version is available. Please refresh the page to update.
            <button class="btn btn-sm btn-warning ms-2" @onclick="RefreshPage" disabled="@IsReloading">
                @if (IsReloading)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    <span>Reloading...</span>
                }
                else
                {
                    <i class="bi bi-arrow-clockwise me-1"></i>
                    <span>Refresh Now</span>
                }
            </button>
            <div class="mt-2">
                <small>Client: @ClientVersion | Server: @ServerVersion</small>
            </div>
        </div>
    }

    <!-- Dashboard Header -->
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <h1 class="mb-0">
                <i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard
            </h1>
            @if (LastSyncTime.HasValue)
            {
                <small class="text-muted">Last updated: @LastSyncTime.Value.ToString("dd/MM/yyyy HH:mm") (@GetTimeSinceLastSync())</small>
            }
            else
            {
                <small class="text-warning"><i class="bi bi-exclamation-circle me-1"></i>No data synced yet</small>
            }
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-primary" @onclick="StartSync" disabled="@IsSyncing">
                @if (IsSyncing)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                }
                else
                {
                    <i class="bi bi-arrow-repeat me-2"></i>
                }
                @GetSyncButtonText()
            </button>
            @if (!IsSyncing)
            {
                <div class="btn-group" role="group">
                    <button type="button" class="btn btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-gear me-1"></i>Options
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        @if (LastSyncTime.HasValue)
                        {
                            <li>
                                <button class="dropdown-item" @onclick="StartFullSync">
                                    <i class="bi bi-arrow-clockwise me-2"></i>Force Full Sync
                                    <small class="text-muted d-block">Download all data (slower but complete)</small>
                                </button>
                            </li>
                        }
                        <li>
                            <button class="dropdown-item text-danger" @onclick="DeleteAllData">
                                <i class="bi bi-trash me-2"></i>Delete All Data
                                <small class="text-muted d-block">Remove all synced data from local database</small>
                            </button>
                        </li>
                    </ul>
                </div>
            }
        </div>
    </div>

    @if (IsSyncing)
    {
        <div class="card mb-4 border-primary">
            <div class="card-body">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></span>
                    <strong>@CurrentAction</strong>
                    @if (IsWakeLockActive)
                    {
                        <small class="text-success ms-2"><i class="bi bi-shield-fill-check me-1"></i>Screen wake lock active</small>
                    }
                </div>
                <div class="progress" style="height: 8px;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: @Progress%;" aria-valuenow="@Progress" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <small class="text-muted mt-1 d-block">@Progress%</small>
            </div>
        </div>
    }

    @if (HasDashboardData)
    {
        <!-- KPI Cards -->
        <div class="row g-3 mb-4">
            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-start justify-content-between">
                            <div>
                                <p class="text-muted small mb-1">Total Portfolio Value</p>
                                <h3 class="mb-0 fw-bold">
                                    <PrivacyValue Value="@($"{TotalPortfolioValue:N2} {PortfolioCurrency}")" />
                                </h3>
                            </div>
                            <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                                <i class="bi bi-wallet2 text-primary fs-4"></i>
                            </div>
                        </div>
                        <hr class="my-2" />
                        <small class="text-muted">
                            <i class="bi bi-grid me-1"></i>@HoldingCount holding@(HoldingCount != 1 ? "s" : "")
                        </small>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-start justify-content-between">
                            <div>
                                <p class="text-muted small mb-1">Total Invested</p>
                                <h3 class="mb-0 fw-bold">
                                    <PrivacyValue Value="@($"{TotalInvested:N2} {PortfolioCurrency}")" />
                                </h3>
                            </div>
                            <div class="rounded-circle bg-info bg-opacity-10 p-3">
                                <i class="bi bi-cash-stack text-info fs-4"></i>
                            </div>
                        </div>
                        <hr class="my-2" />
                        <small class="text-muted">Capital deployed</small>
                    </div>
                </div>
            </div>

            @{
                var gainClass = TotalGainLoss >= 0 ? "success" : "danger";
                var gainIcon = TotalGainLoss >= 0 ? "bi-graph-up-arrow" : "bi-graph-down-arrow";
                var gainSign = TotalGainLoss >= 0 ? "+" : "";
            }
            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-start justify-content-between">
                            <div>
                                <p class="text-muted small mb-1">Total Gain / Loss</p>
                                <h3 class="mb-0 fw-bold text-@gainClass">
                                    <PrivacyValue Value="@($"{gainSign}{TotalGainLoss:N2} {PortfolioCurrency}")" />
                                </h3>
                            </div>
                            <div class="rounded-circle bg-@gainClass bg-opacity-10 p-3">
                                <i class="bi @gainIcon text-@gainClass fs-4"></i>
                            </div>
                        </div>
                        <hr class="my-2" />
                        <small class="text-@gainClass fw-semibold">@gainSign@TotalGainLossPercentage.ToString("N2")%</small>
                        <small class="text-muted"> return on investment</small>
                    </div>
                </div>
            </div>

            @{
                var dividendCount = UpcomingDividends.Count;
                var dividendTotal = UpcomingDividends.Where(d => d.AmountPrimaryCurrency.HasValue).Sum(d => d.AmountPrimaryCurrency!.Value);
                var dividendCurrency = UpcomingDividends.FirstOrDefault(d => !string.IsNullOrEmpty(d.PrimaryCurrency))?.PrimaryCurrency ?? PortfolioCurrency;
            }
            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-start justify-content-between">
                            <div>
                                <p class="text-muted small mb-1">Upcoming Dividends</p>
                                <h3 class="mb-0 fw-bold">
                                    @if (dividendCount > 0)
                                    {
                                        <PrivacyValue Value="@($"{dividendTotal:N2} {dividendCurrency}")" />
                                    }
                                    else
                                    {
                                        <span class="text-muted" style="font-size:1.1rem;">None scheduled</span>
                                    }
                                </h3>
                            </div>
                            <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                                <i class="bi bi-calendar-event text-warning fs-4"></i>
                            </div>
                        </div>
                        <hr class="my-2" />
                        <small class="text-muted">@dividendCount upcoming payment@(dividendCount != 1 ? "s" : "")</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Best & Worst Performer -->
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-success bg-opacity-10 border-0">
                        <h6 class="mb-0 text-success"><i class="bi bi-trophy me-2"></i>Best Performer</h6>
                    </div>
                    <div class="card-body">
                        @if (BestPerformer != null)
                        {
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                                    <i class="bi bi-arrow-up-circle text-success fs-3"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-bold">@BestPerformer.Name</div>
                                    <small class="text-muted">@(BestPerformer.Symbols?.FirstOrDefault() ?? string.Empty)</small>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold text-success fs-5">+@((BestPerformer.GainLossPercentage * 100).ToString("N2"))%</div>
                                    <small class="text-muted"><PrivacyValue Value="@($"{BestPerformer.CurrentValue.Amount:N2} {BestPerformer.Currency}")" /></small>
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No data available</p>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-danger bg-opacity-10 border-0">
                        <h6 class="mb-0 text-danger"><i class="bi bi-exclamation-diamond me-2"></i>Worst Performer</h6>
                    </div>
                    <div class="card-body">
                        @if (WorstPerformer != null && WorstPerformer != BestPerformer)
                        {
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle bg-danger bg-opacity-10 p-3">
                                    <i class="bi bi-arrow-down-circle text-danger fs-3"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-bold">@WorstPerformer.Name</div>
                                    <small class="text-muted">@(WorstPerformer.Symbols?.FirstOrDefault() ?? string.Empty)</small>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold text-danger fs-5">@((WorstPerformer.GainLossPercentage * 100).ToString("N2"))%</div>
                                    <small class="text-muted"><PrivacyValue Value="@($"{WorstPerformer.CurrentValue.Amount:N2} {WorstPerformer.Currency}")" /></small>
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No data available</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Top Holdings Table -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between">
                <h6 class="mb-0"><i class="bi bi-list-ul me-2 text-primary"></i>Top Holdings by Value</h6>
                <a href="/holdings" class="btn btn-sm btn-outline-primary">View All <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Symbol</th>
                                <th class="text-end">Value</th>
                                <th class="text-end">Gain / Loss</th>
                                <th class="text-end">Weight</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var holding in Holdings.OrderByDescending(h => h.CurrentValue.Amount).Take(10))
                            {
                                var rowGainClass = holding.GainLossPercentage >= 0 ? "text-success" : "text-danger";
                                var rowGainSign = holding.GainLossPercentage >= 0 ? "+" : "";
                                <tr>
                                    <td class="fw-semibold">@holding.Name</td>
                                    <td><span class="badge bg-secondary">@(holding.Symbols?.FirstOrDefault() ?? "-")</span></td>
                                    <td class="text-end"><PrivacyValue Value="@($"{holding.CurrentValue.Amount:N2} {holding.Currency}")" /></td>
                                    <td class="text-end @rowGainClass fw-semibold">@rowGainSign@((holding.GainLossPercentage * 100).ToString("N2"))%</td>
                                    <td class="text-end">
                                        <div class="d-flex align-items-center justify-content-end gap-2">
                                            <div class="progress flex-grow-1" style="height:6px; max-width:60px;">
                                                <div class="progress-bar bg-primary" style="width:@((int)Math.Min(holding.Weight * 100, 100))%;"></div>
                                                            </div>
                                                            <small>@((holding.Weight * 100).ToString("N1"))%</small>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @if (UpcomingDividends.Count > 0)
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between">
                    <h6 class="mb-0"><i class="bi bi-calendar2-event me-2 text-warning"></i>Upcoming Dividends</h6>
                    <a href="/dividends" class="btn btn-sm btn-outline-warning">View All <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Company</th>
                                    <th>Symbol</th>
                                    <th class="text-end">Ex-Date</th>
                                    <th class="text-end">Pay Date</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var div in UpcomingDividends)
                                {
                                    <tr>
                                        <td class="fw-semibold">@div.CompanyName</td>
                                        <td><span class="badge bg-secondary">@div.Symbol</span></td>
                                        <td class="text-end">@div.ExDate.ToString("dd/MM/yyyy")</td>
                                        <td class="text-end">@div.PaymentDate.ToString("dd/MM/yyyy")</td>
                                        <td class="text-end">
                                            @if (div.AmountPrimaryCurrency.HasValue)
                                            {
                                                <PrivacyValue Value="@($"{div.AmountPrimaryCurrency.Value:N2} {div.PrimaryCurrency}")" />
                                            }
                                            else
                                            {
                                                <PrivacyValue Value="@($"{div.Amount:N2} {div.Currency}")" />
                                            }
                                            @if (div.IsPredicted)
                                            {
                                                <span class="badge bg-warning text-dark ms-1" title="Predicted">~</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
    else if (!LastSyncTime.HasValue)
    {
        <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body">
                <i class="bi bi-cloud-download display-1 text-muted mb-3"></i>
                <h4>Welcome to Portfolio Viewer</h4>
                <p class="text-muted mb-4">Sync your portfolio data to see your dashboard KPIs, holdings overview, and upcoming dividends.</p>
                <button class="btn btn-primary btn-lg" @onclick="StartSync" disabled="@IsSyncing">
                    <i class="bi bi-arrow-repeat me-2"></i>Start Initial Sync
                </button>
                <div class="mt-3">
                    <small class="text-muted"><i class="bi bi-info-circle me-1"></i>First sync downloads all data and may take a few minutes.</small>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>No holdings found in the database. Please sync your data to view the dashboard.
        </div>
    }

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <div class="alert @(_isError ? "alert-danger" : "alert-success") mt-3" role="alert">
            <i class="bi @(_isError ? "bi-exclamation-triangle" : "bi-check-circle") me-2"></i>
            @_statusMessage
        </div>
    }

    @if (!IsUpdateAvailable && !string.IsNullOrEmpty(ClientVersion))
    {
        <footer class="text-center mt-5 mb-2 text-muted" style="font-size: 0.95em;">
            <i class="bi bi-info-circle me-1"></i>
            Version: @ClientVersion
            @if (!string.IsNullOrEmpty(ServerVersion))
            {
                <span class="text-success ms-2">
                    <i class="bi bi-check-circle me-1"></i>
                    Up to date
                </span>
            }
        </footer>
    }
}
